{
  "extends": "@vue/tsconfig/tsconfig.node.json",
  "include": ["src/main/**/*", "src/shared/**/*", "electron.vite.config.*"],
  "exclude": ["src/renderer/**/*", "src/preload/**/*"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["src/shared/*"],
      "@main/*": ["src/main/*"]
    }
  }
}