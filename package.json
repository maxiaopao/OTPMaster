{
  "name": "otpmaster-electron",
  "version": "1.0.0",
  "description": "OTPMaster-Electron 是一个基于 Electron 的 macOS 桌面应用程序，用于自动提取短信和邮箱验证码并实现自动粘贴和回车功能",
  "main": "out/main/index.js",
  "author": "OTPMaster Team",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "npm run build && electron-builder --mac",
    "start": "electron out/main/index.js"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.otpmaster.electron",
    "productName": "OTPMaster",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out",
      "node_modules/sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "asarUnpack": [
      "node_modules/sqlite3/**/*"
    ],
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.utilities",
      "target": {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      "icon": "build/icons/icon.icns",
      "entitlements": "build/entitlements.plist",
      "entitlementsInherit": "build/entitlements.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "electron",
    "sms",
    "verification",
    "automation",
    "macos",
    "vue"
  ]
}
